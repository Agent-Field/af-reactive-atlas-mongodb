# Required
OPENROUTER_API_KEY=sk-or-v1-...

# Required - MongoDB Atlas connection string
# Get from: Atlas UI -> Your Cluster -> Connect -> Drivers -> Copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/reactive_intelligence?retryWrites=true&w=majority

# Required - public URL from cloudflared tunnel (used in Atlas Trigger)
# Run: cloudflared tunnel --url http://localhost:8092
# Copy the https://xxx.trycloudflare.com URL
AGENTFIELD_PUBLIC_URL=https://xxx.trycloudflare.com

# Optional
MONGODB_DATABASE=reactive_intelligence
AI_MODEL=openrouter/minimax/minimax-m2.5
